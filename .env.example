# Environment
NODE_ENV=development

# Solana Configuration
SOLANA_CLUSTER=devnet
SOLANA_RPC_URL=https://api.devnet.solana.com

# Policy Configuration
MAX_SPEND_LAMPORTS=1000000000
MAX_TX_PER_MINUTE=10
ALLOWED_PROGRAMS=11111111111111111111111111111111,TokenkegQfeZyiNwAJbNbGKPFXCWuBvf9Ss623VQ5DA

# Logging
LOG_LEVEL=debug

# Simulation
SIMULATION_AGENT_COUNT=2
SIMULATION_ROUNDS=5
AIRDROP_LAMPORTS=2000000000

# AI / LLM
# Required: get your key at https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=your-google-api-key-here
# Optional: override model (default: gemini-2.0-flash)
# GEMINI_MODEL=gemini-2.5-flash
